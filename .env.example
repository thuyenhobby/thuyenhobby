NEXT_PUBLIC_SITE_URL=

# Public R2 asset base URL. Safe to use in client components.
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-r2-public-url.r2.dev

# Server-only R2 credentials. Do not expose these in client components.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Simple admin protection for /admin/bookshelf and admin APIs.
ADMIN_SECRET=
